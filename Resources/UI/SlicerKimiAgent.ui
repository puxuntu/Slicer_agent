      <item row="1" column="0">
       <widget class="QLabel" name="githubTokenLabel">
        <property name="text">
         <string>GitHub Token:</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <layout class="QHBoxLayout" name="githubTokenLayout">
        <item>
         <widget class="QLineEdit" name="githubTokenInput">
          <property name="echoMode">
           <enum>QLineEdit::Password</enum>
          </property>
          <property name="placeholderText">
           <string>Required for code search - get at github.com/settings/tokens</string>
          </property>
          <property name="toolTip">
           <string>GitHub personal access token (classic) with 'public_repo' scope. Code search requires authentication.</string>
          </property>
         </widget>
        </item>
        <item>
