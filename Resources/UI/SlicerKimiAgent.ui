       </property>
       <property name="toolTip">
        <string>Execute the generated Python code</string>
       </property>
       <property name="styleSheet">
        <string notr="true">QPushButton {
    background-color: #4CAF50;
    color: white;
    border: none;
    padding: 5px 15px;
    border-radius: 4px;
}
QPushButton:hover {
    background-color: #45a049;
}
