     <layout class="QFormLayout" name="onlineSearchFormLayout">
      <item row="0" column="0">
       <widget class="QLabel" name="onlineSearchLabel">
        <property name="text">
         <string>Online Search:</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QCheckBox" name="onlineSearchCheckbox">
        <property name="text">
         <string>Enable online knowledge search</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
        <property name="toolTip">
         <string>Search Slicer GitHub repository for additional code examples. Requires GitHub token for code search.</string>
