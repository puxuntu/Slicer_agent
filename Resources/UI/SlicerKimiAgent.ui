          <property name="text">
           <string>Test</string>
          </property>
          <property name="toolTip">
           <string>Test GitHub connection and token validity</string>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item row="2" column="0" colspan="2">
       <widget class="QPushButton" name="saveOnlineSettingsButton">
        <property name="text">
         <string>Save Online Search Settings</string>
        </property>
        <property name="toolTip">
         <string>Save online knowledge search settings</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   
